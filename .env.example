# Copy to .env.demo or .env.live. Do not commit real secrets.

OKX_ENV=demo
OKX_API_KEY=
OKX_API_SECRET=
# OKX passphrase is the API password you set when creating the key.
# It is not the secret key and usually cannot be viewed later.
OKX_API_PASSPHRASE=
OKX_SIMULATED_TRADING=1
# Official recommended REST domain as of OKX API docs 2026-05-20.
OKX_REST_BASE_URL=https://openapi.okx.com
# Optional proxy for servers that cannot reach OKX REST directly.
# Python urllib honors these environment variables.
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=

LIVE_CAPITAL_LIMIT_USDT=300
READ_ONLY_MODE=1
KILL_SWITCH=0
